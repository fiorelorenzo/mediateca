# Local secrets (never commit — see .env.template for the schema)
.env

# Persistent app state created at runtime
config/*
downloads/
caddy/data/
caddy/config/

# Headscale config.yaml is a checked-in template (no secrets); the runtime
# data/ subtree (private keys, sqlite DB) stays ignored.
!config/headscale/
config/headscale/*
!config/headscale/config.yaml
!config/jellyfin-custom.css
!config/streamyfin/
!config/streamyfin/plugin-config.yml
!config/orchestrator/
!config/orchestrator/policy.yml
!config/recyclarr/
!config/recyclarr/recyclarr.yml
!config/recyclarr/.gitignore
!config/recyclarr/custom-formats/
!config/recyclarr/custom-formats/*.json
!config/recyclarr/custom-formats/README.md

# Tooling
.claude/
.DS_Store

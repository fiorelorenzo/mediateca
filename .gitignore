# Local secrets (never commit — see .env.template for the schema)
.env

# Persistent app state created at runtime
config/*
downloads/
!admin-app/src/app/\(app\)/downloads/
caddy/data/
caddy/config/

# Headscale config.yaml is a checked-in template (no secrets); the runtime
# data/ subtree (private keys, sqlite DB) stays ignored.
!config/headscale/
config/headscale/*
!config/headscale/config.yaml
!config/jellyfin-custom.css
!config/streamyfin/
!config/streamyfin/plugin-config.yml
!config/orchestrator/
!config/orchestrator/policy.yml
!config/recyclarr/
!config/recyclarr/recyclarr.yml
!config/recyclarr/.gitignore
!config/recyclarr/custom-formats/
!config/recyclarr/custom-formats/*.json
!config/recyclarr/custom-formats/README.md

# AI workflow artifacts (brainstorming output, plans, internal scratch).
# Keep them locally for context but they are not part of the project.
docs/superpowers/

# Python
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
env/

# Test/lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Node (future admin app)
node_modules/
.next/
.turbo/
*.tsbuildinfo

# Playwright artifacts
admin-app/test-results/
admin-app/playwright-report/
admin-app/.playwright/

# Editor / OS
.DS_Store
*.bak
*.swp
*~
.idea/
.vscode/

# Tooling
.claude/

# Backup SSH keys — never commit
backup/ssh/*
!backup/ssh/.gitkeep
orchestrator/uv.lock

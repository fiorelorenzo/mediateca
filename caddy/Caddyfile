# Caddy reverse proxy + automatic HTTPS via Let's Encrypt.
# Container env reads: {$DOMAIN}, {$ACME_EMAIL}.
#
# Layout:
#   media.{$DOMAIN}       → Jellyfin (streaming UI)
#   seerr.{$DOMAIN}       → Seerr (request management)
#   <app>.{$DOMAIN}       → other apps, one subdomain each
#
# Auth: each app handles its own (Sonarr/Radarr/Prowlarr/Bazarr →
# Settings → General → Authentication = "Forms"; qBittorrent has its own
# WebUI auth; Jellyfin/Seerr have native login).

{
    email {$ACME_EMAIL}
}

media.{$DOMAIN} {
    reverse_proxy jellyfin:8096
}

# Public-facing entry point. The URL we hand out to non-technical users
# (family, friends). They land on the Seerr request UI, log in with
# Jellyfin credentials (Seerr local login is disabled, only mediaServerLogin
# is exposed), browse the catalog, and the "Play on Jellyfin" button
# bounces them to media.{$DOMAIN} for items already in the library —
# routed through seerr-inject (tiny nginx) which rewrites the HTML
# response so Jellyfin links open in the same tab. See
# docker-compose.yml + caddy/seerr-inject.conf.
streaming.{$DOMAIN} {
    reverse_proxy seerr-inject:80
}

sonarr.{$DOMAIN} {
    reverse_proxy sonarr:8989
}

radarr.{$DOMAIN} {
    reverse_proxy radarr:7878
}

prowlarr.{$DOMAIN} {
    reverse_proxy prowlarr:9696
}

bazarr.{$DOMAIN} {
    reverse_proxy bazarr:6767
}

orchestrator.{$DOMAIN} {
    reverse_proxy orchestrator:8000
}

qbit.{$DOMAIN} {
    reverse_proxy gluetun:8080
}

headscale.{$DOMAIN} {
    reverse_proxy headscale:8080
}

# Dispatcharr — IPTV middleware (active fork of xTeVe/Threadfin). Aggregates
# M3U playlists, applies XMLTV EPG, exposes HDHomeRun emulator on the same
# port; Jellyfin's Live TV auto-discovers it as a virtual tuner.
tv.{$DOMAIN} {
    reverse_proxy dispatcharr:9191
}

encoder-status.{$DOMAIN} {
    # Read-only snapshot of the hls-encoder queue state. Refreshed by
    # the encoder every STATUS_INTERVAL seconds (default 10s). Pollable
    # by cron / Prometheus blackbox.
    header {
        Cache-Control "no-store"
        Access-Control-Allow-Origin "*"
    }
    root * /srv/encoder-status
    file_server
}

hls.{$DOMAIN} {
    # Public HLS CDN: serves segments + playlists from the Storage Box
    # mounted read-only at /srv/hls in the Caddy container. CORS is open
    # so HLS.js (browser Jellyfin) can fetch cross-origin if a future
    # client lives on a different host.
    header {
        Cache-Control "public, max-age=86400, immutable"
        Access-Control-Allow-Origin "*"
    }
    encode gzip
    file_server {
        root /srv/hls
    }
}
